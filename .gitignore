# disposable per-run sandboxes (the loop copies tasks here)
.runs/

# append-only run ledger (regenerated by loop.sh / the panel)
runs.jsonl

# transient compare.sh run log (the matrix itself is results/comparison.md)
results/*.log

# loop-generated artifacts inside the cloned loops
loops/01-grading-loop/out/
loops/01-grading-loop/grades.jsonl
loops/01-grading-loop/review-queue/

# secrets — your Telegram bot token lives here, never committed
.env.telegram
.env*.local

# os cruft
.DS_Store

# vercel CLI project link
.vercel

# crucible benchmark — generated battery artifacts (the spec, code, schemas & tasks ARE tracked)
crucible/results/*.jsonl
crucible/results/*.log
