# disposable per-run sandboxes (the loop copies tasks here)
.runs/
# local archives of old .runs evidence (kept out of git)
runs-archive-*.tar.gz

# append-only run ledger (regenerated by loop.sh / the panel)
runs.jsonl

# transient compare.sh run log (the matrix itself is results/comparison.md)
results/*.log

# loop-generated artifacts inside the cloned loops
loops/01-grading-loop/out/
loops/01-grading-loop/grades.jsonl
loops/01-grading-loop/review-queue/

# secrets — your Telegram bot token lives here, never committed
.env.telegram
.env*.local

# os cruft
.DS_Store

# vercel CLI project link
.vercel

# crucible benchmark — generated battery artifacts (the spec, code, schemas & tasks ARE tracked)
crucible/results/*.jsonl
crucible/results/*.log
# ...but the FROZEN published snapshot IS tracked, so the writeup's numbers are reproducible
# from committed data and the docs↔data claims guard can run in CI (crucible/audit-claims.js).
!crucible/results/battery.published.jsonl

# aider harness local droppings (created when the aider adapter runs)
.aider.chat.history.md
.aider.input.history
.aider*
# qwen3.5 study ledgers (pre-registered arms — frozen evidence, committed)
!crucible/results/qwen35-pilot.jsonl
!crucible/results/qwen35-think-off.jsonl
!crucible/results/qwen35-think-on-repl.jsonl
!crucible/results/qwen35-hermes-fix.jsonl

# per-battery integrity/canary sidecars (transient)
crucible/results/*.integrity.jsonl
crucible/results/*.canary.jsonl
!crucible/results/cloud-b2.jsonl
!crucible/results/cloud-claude-t1.jsonl
!crucible/results/cloud-openai-metered.jsonl
!crucible/results/qwen35-t0-calib.jsonl
!crucible/results/qwen35-scaled.jsonl
# phase D confirmatory arm (3rd family, pre-registered) — frozen evidence, committed
# (canary sidecar included: claim 28 in audit-claims.js asserts on it in CI)
!crucible/results/phase-d-llama.jsonl
!crucible/results/phase-d-llama.canary.jsonl
!crucible/results/llama-t0-calib.jsonl
# Sprint 2 external anchor (Terminal-Bench slice) — frozen evidence, committed
!crucible/results/anchor-tb.jsonl
!crucible/results/anchor-t0-calib.jsonl

# harness sandbox-escape artifacts (tasks leak these to repo root; never commit)
.lock-seen
/config/
/report.txt
/.roots/
