# Copy this file to  .env.telegram  and fill in the values.
#   cp .env.telegram.example .env.telegram
#
# .env.telegram is gitignored — keep your token HERE, never paste it into chat or
# put it on the command line (it would leak into shell history / process lists).

# From @BotFather (/newbot -> copy the token):
TELEGRAM_BOT_TOKEN=123456789:PASTE-YOUR-BOTFATHER-TOKEN-HERE

# Comma-separated chat IDs allowed to control the fleet (hard allowlist).
# Find yours: message your bot once, then run `node telegram-whoami.js`.
TELEGRAM_ALLOWED_CHATS=

# Optional — panel port (default 8088)
PANEL_PORT=8088
